{
  "expo": {
    "name": "Voxly",
    "slug": "voxly",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "voxly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Voxly needs microphone access to record voice notes.",
        "NSPhotoLibraryUsageDescription": "Voxly needs access to import audio files."
      }
    },
    "android": {
      "package": "com.rishai.voxly",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0C0E14",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0C0E14",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2185ed0b-eb1b-49a2-845a-79df335e4139"
      }
    },
    "owner": "rishai_0913",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2185ed0b-eb1b-49a2-845a-79df335e4139"
    }
  }
}
