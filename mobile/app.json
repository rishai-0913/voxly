{
  "expo": {
    "name": "Voxly",
    "slug": "voxly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "voxly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Voxly needs microphone access to record voice notes.",
        "NSPhotoLibraryUsageDescription": "Voxly needs access to import audio files."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0C0E14",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-font",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
