GROQ_API_KEY=gsk_your_key_here
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/voxly
APP_ENV=development
MAX_AUDIO_DURATION_SECONDS=300

# Twilio Verify — https://console.twilio.com
